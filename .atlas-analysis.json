  "keyFeatures": [
    "57+ accessible React components built on Radix UI",
    "CLI tool for component installation and management",
    "Custom registry system for component distribution",
    "Tailwind CSS theming with CSS variables",
    "Cross-framework support (Next.js, Vite, Remix, Astro, etc.)",
    "Pre-built blocks and templates",
    "Dark mode support",
    "TypeScript and JavaScript support",
    "Open code philosophy - components owned by developers"
  ],
  "publicApiSurface": [
    "shadcn init - Initialize project configuration",
    "shadcn create - Create new project with custom design system",
    "shadcn add [component] - Add components to project",
    "shadcn diff [component] - View component diff",
    "shadcn view [component] - View component source",
    "shadcn search [query] - Search for components",
    "shadcn migrate - Run migrations",
    "shadcn info - View project info",
    "shadcn build - Build registry",
    "shadcn registry - Manage custom registries",
    "shadcn mcp - Model Context Protocol integration",
    "components.json - Configuration file",
    "Registry API - Custom component distribution",
    "Component exports (Button, Dialog, Form, etc.)",
    "Theming system with CSS variables",
    "Block/template system"
  ]
